# Only load interactive shell customizations when NOT in Claude Code
if [[ -z "$CLAUDE_CODE" ]]; then
    # ── Editor ──────────────────────────────────────────────────────
    alias vim="nvim"
    alias v="nvim"
    alias vi="nvim"

    # ── Modern replacements ────────────────────────────────────────
    # eza replaces ls (colours, git status, icons)
    alias ls="eza --group-directories-first"
    alias ll="eza -la --group-directories-first --git"
    alias la="eza -a --group-directories-first"
    alias lt="eza -la --sort=modified"
    alias tree="eza --tree --level=3"

    # bat replaces cat (syntax highlighting, line numbers)
    alias cat="bat --paging=never"
    alias catp="bat"  # with pager

    # fd replaces find
    alias ff="fd --type f"   # find files
    alias fdir="fd --type d" # find directories

    # zoxide replaces cd (z jumps to frecent dirs)
    alias cd="z"
    alias cdi="zi"  # interactive picker

    # ── Git shortcuts ──────────────────────────────────────────────
    alias gs="git status"
    alias gd="git diff"
    alias gds="git diff --staged"
    alias gl="git log --oneline -20"
    alias glg="git log --oneline --graph --all -30"
    alias gco="git checkout"
    alias gcb="git checkout -b"
    alias gp="git pull"
    alias gf="git fetch --all --prune"

    # ── Tmux ───────────────────────────────────────────────────────
    alias ta="tmux attach -t"
    alias tn="tmux new -s"
    alias tls="tmux ls"
    alias tk="tmux kill-session -t"

    # ── Misc ───────────────────────────────────────────────────────
    alias reload="source ~/.zshrc"
    alias path='echo $PATH | tr ":" "\n"'
    alias ports="lsof -iTCP -sTCP:LISTEN -P -n"
    alias myip="curl -s ifconfig.me"
    alias kssh="kitty +kitten ssh"  # use kssh when you want Kitty's SSH kitten
    alias weather="curl wttr.in/?format=3"
fi
